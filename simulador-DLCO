<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FPAIR · Simulador DLCO (maniobra corregida)</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
        }

        body {
            background: #f2f7ff;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 24px;
        }

        .simulator-container {
            max-width: 1600px;
            width: 100%;
            background: #ffffff;
            border-radius: 40px;
            padding: 32px;
            box-shadow: 0 20px 40px rgba(0, 40, 80, 0.12), 0 8px 20px rgba(0, 60, 120, 0.1);
            border: 1px solid #e6f0ff;
        }

        /* HEADER con logo FPAIR */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid #d9e8ff;
        }

        .logo-area {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .logo-fpair {
            background: #0057a3;
            width: 60px;
            height: 60px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
            font-weight: 700;
            color: white;
            box-shadow: 0 6px 14px rgba(0, 87, 163, 0.3);
        }

        .logo-text h2 {
            color: #002b4f;
            font-weight: 300;
            font-size: 1.9rem;
            letter-spacing: -0.5px;
            line-height: 1.2;
        }

        .logo-text h2 span {
            color: #0057a3;
            font-weight: 600;
        }

        .logo-text .sub {
            color: #5f7d9c;
            font-size: 0.8rem;
            letter-spacing: 0.3px;
            margin-top: 4px;
        }

        .status-panel {
            display: flex;
            align-items: center;
            gap: 24px;
            background: #eef5ff;
            padding: 12px 28px;
            border-radius: 60px;
            border: 1px solid #c8ddff;
        }

        .live-badge {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .pulse-dot {
            width: 14px;
            height: 14px;
            background: #00b383;
            border-radius: 50%;
            box-shadow: 0 0 8px #00b383;
            animation: softPulse 2s infinite;
        }

        .live-text {
            color: #0057a3;
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
        }

        .phase-tags {
            display: flex;
            gap: 10px;
        }

        .phase-tag {
            padding: 6px 16px;
            border-radius: 30px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            background: #ffffff;
            color: #3a5f8a;
            border: 1px solid #b9d3ff;
            transition: 0.2s;
        }

        .phase-tag.active-insp {
            background: #0057a3;
            color: white;
            border-color: #0057a3;
            box-shadow: 0 2px 8px #0057a3;
        }

        .phase-tag.active-exp {
            background: #c44545;
            color: white;
            border-color: #c44545;
        }

        .phase-tag.active-pause {
            background: #5f7d9c;
            color: white;
            border-color: #5f7d9c;
        }
        .phase-tag.active-hold {
            background: #9b59b6;
            color: white;
            border-color: #9b59b6;
        }

        @keyframes softPulse {
            0% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.7; transform: scale(1.12); }
            100% { opacity: 1; transform: scale(1); }
        }

        /* GRAFICO ARRIBA */
        .graph-area {
            margin-bottom: 24px;
            background: #ffffff;
            border-radius: 32px;
            padding: 20px;
            border: 1px solid #d2e3ff;
            box-shadow: 0 8px 18px rgba(0,60,120,0.06);
        }

        .graph-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
            color: #1e3f66;
            font-weight: 400;
        }

        .graph-container {
            position: relative;
            width: 100%;
            border-radius: 24px;
            overflow: hidden;
            background: #fafdff;
            border: 1px solid #c7ddff;
        }

        canvas {
            width: 100%;
            height: auto;
            display: block;
        }

        /* INFO DEBAJO DEL CANVAS */
        .graph-info-bar {
            display: flex;
            justify-content: space-between;
            background: #eef5ff;
            border-radius: 40px;
            padding: 16px 28px;
            margin-top: 16px;
            border: 1px solid #bfd8ff;
        }

        .info-block {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .info-label {
            color: #4a6d94;
            font-size: 0.7rem;
            text-transform: uppercase;
        }

        .info-value {
            color: #002b4f;
            font-size: 1.3rem;
            font-weight: 500;
        }
        .info-value span {
            color: #0057a3;
            font-weight: 600;
        }

        /* Leyenda colores */
        .legend-slim {
            display: flex;
            gap: 24px;
            margin-top: 18px;
            flex-wrap: wrap;
            background: #edf5ff;
            padding: 14px 22px;
            border-radius: 50px;
            border: 1px solid #bfd8ff;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #2b4f79;
            font-size: 0.8rem;
        }

        .color-dot {
            width: 14px;
            height: 14px;
            border-radius: 4px;
        }

        /* BOTÓN DE MANIOBRA DLCO */
        .maneuver-button-large {
            background: linear-gradient(145deg, #0057a3, #003f7a);
            border: none;
            color: white;
            padding: 20px 20px;
            border-radius: 60px;
            font-weight: 600;
            font-size: 1.2rem;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
            width: 100%;
            margin: 20px 0 10px;
            box-shadow: 0 10px 22px rgba(0, 87, 163, 0.3);
            border: 1px solid #8fc5ff;
            transition: 0.2s;
            cursor: pointer;
        }

        .maneuver-button-large:hover {
            transform: translateY(-2px);
            background: linear-gradient(145deg, #0066b3, #004b8f);
            box-shadow: 0 16px 28px rgba(0,87,163,0.4);
        }

        .maneuver-status-badge {
            background: #e7f0ff;
            border-radius: 40px;
            padding: 14px 20px;
            color: #003f7a;
            font-size: 0.9rem;
            border-left: 6px solid #0057a3;
            margin: 10px 0 20px;
        }

        /* CONTROLES (debajo) */
        .controls-wrapper {
            display: flex;
            flex-direction: column;
            gap: 28px;
        }

        .param-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 24px;
        }

        .card-panel {
            background: #f6faff;
            border-radius: 28px;
            padding: 22px 24px;
            border: 1px solid #d0e3ff;
            box-shadow: 0 5px 12px rgba(0,40,80,0.04);
        }

        .card-title {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #00315a;
            font-size: 0.9rem;
            letter-spacing: 0.5px;
            margin-bottom: 24px;
            text-transform: uppercase;
            border-bottom: 1px dashed #b7d2ff;
            padding-bottom: 12px;
        }

        .volumes-mini-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .vol-readout {
            background: #ffffff;
            border-radius: 20px;
            padding: 14px;
            border-left: 4px solid #0057a3;
            box-shadow: 0 2px 6px #dde9ff;
        }

        .vol-label {
            color: #5f7d9c;
            font-size: 0.7rem;
            text-transform: uppercase;
        }

        .vol-number {
            color: #002b4f;
            font-size: 1.7rem;
            line-height: 1.2;
            font-weight: 300;
        }

        .vol-unit {
            color: #7b99bb;
            font-size: 0.8rem;
            margin-left: 4px;
        }

        .slider-group {
            margin-bottom: 22px;
        }

        .slider-header {
            display: flex;
            justify-content: space-between;
            color: #1f446b;
            font-size: 0.85rem;
            margin-bottom: 6px;
        }

        .slider-header span:last-child {
            background: #deebff;
            padding: 3px 14px;
            border-radius: 40px;
            color: #0057a3;
            font-weight: 600;
            font-size: 0.75rem;
        }

        input[type=range].slider {
            width: 100%;
            height: 5px;
            background: #cddeff;
            border-radius: 10px;
            -webkit-appearance: none;
        }

        input[type=range].slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 20px;
            height: 20px;
            background: #0057a3;
            border-radius: 50%;
            cursor: pointer;
            box-shadow: 0 2px 8px #0057a3;
            border: 2px solid white;
        }

        .numeric-input {
            background: white;
            border: 1px solid #b9d3ff;
            color: #002b4f;
            padding: 8px 12px;
            width: 80px;
            border-radius: 30px;
            text-align: center;
            font-weight: 600;
        }

        .dual-input {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 8px;
        }

        .dlco-predicho {
            background: #ffffff;
            border-radius: 18px;
            padding: 20px;
            border: 1px solid #caddff;
            text-align: center;
        }

        .dlco-predicho .label {
            color: #5f7d9c;
            font-size: 0.8rem;
        }

        .dlco-predicho .value {
            color: #0057a3;
            font-size: 2.5rem;
            font-weight: 300;
            line-height: 1.2;
        }

        .dlco-predicho .unit {
            color: #7b99bb;
            font-size: 1rem;
        }

        .time-controls-modern {
            display: flex;
            gap: 20px;
            align-items: center;
            flex-wrap: wrap;
            margin-top: 10px;
        }

        .btn-icon {
            background: #eaf2ff;
            border: 1px solid #b3cfff;
            color: #003766;
            padding: 12px 25px;
            border-radius: 40px;
            display: flex;
            gap: 10px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
        }

        .btn-icon:hover {
            background: #d1e4ff;
        }
    </style>
</head>
<body>
    <div class="simulator-container">
        <!-- Header con logo FPAIR -->
        <div class="header">
            <div class="logo-area">
                <div class="logo-fpair">FPAIR</div>
                <div class="logo-text">
                    <h2>Pulmo<span>Lab</span> Pro</h2>
                    <div class="sub">Transformando la evaluación pulmonar · ATS/ERS 2019</div>
                </div>
            </div>
            <div class="status-panel">
                <div class="live-badge">
                    <div class="pulse-dot"></div>
                    <span class="live-text" id="liveStatusHeader">VT BASAL</span>
                </div>
                <div class="phase-tags">
                    <div class="phase-tag" id="vtPhaseTag">VT</div>
                    <div class="phase-tag" id="expPhaseTag">EXP</div>
                    <div class="phase-tag" id="inspPhaseTag">INSP</div>
                    <div class="phase-tag" id="holdPhaseTag">HOLD</div>
                </div>
            </div>
        </div>

        <!-- GRAFICO PRINCIPAL (ARRIBA) -->
        <div class="graph-area">
            <div class="graph-header">
                <h3>📈 Volumen pulmonar (L) · Maniobra DLCO (espiración completa → insp max → apnea 8s → espiración)</h3>
            </div>
            <div class="graph-container">
                <canvas id="dlcoCanvas" width="1100" height="400"></canvas>
            </div>
            <!-- INFO DEBAJO DEL CANVAS -->
            <div class="graph-info-bar">
                <div class="info-block">
                    <span class="info-label">Volumen actual</span>
                    <span class="info-value" id="currentVolLive">2.15 <span>L</span></span>
                </div>
                <div class="info-block">
                    <span class="info-label">Fase</span>
                    <span class="info-value" id="currentPhaseLive">VT basal</span>
                </div>
                <div class="info-block">
                    <span class="info-label">DLCO estimada</span>
                    <span class="info-value" id="dlcoLive">-- <span>mL/min/mmHg</span></span>
                </div>
                <div class="info-block">
                    <span class="info-label">TLC / VR</span>
                    <span class="info-value" id="tlcVrLive">5.3 / 1.2 L</span>
                </div>
            </div>

            <!-- Leyenda bajo gráfico -->
            <div class="legend-slim">
                <div class="legend-item"><span class="color-dot" style="background:#4facfe;"></span> VT basal</div>
                <div class="legend-item"><span class="color-dot" style="background:#c44545;"></span> Espiración forzada a VR</div>
                <div class="legend-item"><span class="color-dot" style="background:#2ecc71;"></span> VR (residual)</div>
                <div class="legend-item"><span class="color-dot" style="background:#9b59b6;"></span> TLC (apnea 8s)</div>
                <div class="legend-item"><span class="color-dot" style="background:#f39c12;"></span> Inspiración máxima</div>
                <div class="legend-item"><span class="color-dot" style="background:#0057a3;"></span> VT (volumen corriente)</div>
            </div>
        </div>

        <!-- BOTÓN DE MANIOBRA DLCO justo debajo del gráfico -->
        <button class="maneuver-button-large" id="dlcoManeuverBtn">
            <span>🫁</span> INICIAR MANIOBRA DLCO (espiración a VR → insp TLC → apnea 8s → espiración) <span>⏱️</span>
        </button>
        <div class="maneuver-status-badge" id="maneuverStatus">VT basal · esperando inicio de maniobra</div>

        <!-- CONTROLES DEBAJO (PARÁMETROS MODIFICABLES) -->
        <div class="controls-wrapper">
            <div class="param-grid">
                <!-- Volúmenes pulmonares (esenciales para definir VR, TLC, etc) -->
                <div class="card-panel">
                    <div class="card-title">📊 Volúmenes pulmonares (L) · editable</div>
                    <div class="volumes-mini-grid">
                        <div class="vol-readout"><div class="vol-label">VT</div><div><span class="vol-number" id="vtDisplay">0.5</span><span class="vol-unit">L</span></div></div>
                        <div class="vol-readout"><div class="vol-label">VRI</div><div><span class="vol-number" id="vriDisplay">2.5</span><span class="vol-unit">L</span></div></div>
                        <div class="vol-readout"><div class="vol-label">VRE</div><div><span class="vol-number" id="vreDisplay">1.1</span><span class="vol-unit">L</span></div></div>
                        <div class="vol-readout"><div class="vol-label">VR</div><div><span class="vol-number" id="vrDisplay">1.2</span><span class="vol-unit">L</span></div></div>
                    </div>
                    <!-- Sliders + numérico -->
                    <div class="slider-group">
                        <div class="slider-header"><span>VT</span><span id="vtValLabel">0.50 L</span></div>
                        <input type="range" class="slider" id="vt-slider" min="0.2" max="1.0" value="0.5" step="0.01">
                        <div class="dual-input"><input type="number" class="numeric-input" id="vtNum" value="0.5" step="0.01" min="0.2" max="1.0"></div>
                    </div>
                    <div class="slider-group">
                        <div class="slider-header"><span>VRI</span><span id="vriValLabel">2.50 L</span></div>
                        <input type="range" class="slider" id="vri-slider" min="1.0" max="3.5" value="2.5" step="0.05">
                        <div class="dual-input"><input type="number" class="numeric-input" id="vriNum" value="2.5" step="0.05" min="1.0" max="3.5"></div>
                    </div>
                    <div class="slider-group">
                        <div class="slider-header"><span>VRE</span><span id="vreValLabel">1.10 L</span></div>
                        <input type="range" class="slider" id="vre-slider" min="0.5" max="1.8" value="1.1" step="0.05">
                        <div class="dual-input"><input type="number" class="numeric-input" id="vreNum" value="1.1" step="0.05" min="0.5" max="1.8"></div>
                    </div>
                    <div class="slider-group">
                        <div class="slider-header"><span>VR</span><span id="vrValLabel">1.20 L</span></div>
                        <input type="range" class="slider" id="vr-slider" min="0.8" max="2.0" value="1.2" step="0.05">
                        <div class="dual-input"><input type="number" class="numeric-input" id="vrNum" value="1.2" step="0.05" min="0.8" max="2.0"></div>
                    </div>
                </div>

                <!-- Panel de tiempos de la maniobra (simples) -->
                <div class="card-panel">
                    <div class="card-title">⏱️ Tiempos maniobra DLCO</div>
                    <div class="slider-group">
                        <div class="slider-header"><span>Duración espiración a VR</span><span id="expToVrLabel">3.0 s</span></div>
                        <input type="range" class="slider" id="expToVrSlider" min="1.0" max="5.0" value="3.0" step="0.2">
                        <div class="dual-input"><input type="number" class="numeric-input" id="expToVrNum" value="3.0" step="0.2" min="1.0" max="5.0"></div>
                    </div>
                    <div class="slider-group">
                        <div class="slider-header"><span>Meseta en VR</span><span id="plateauVrLabel">1.0 s</span></div>
                        <input type="range" class="slider" id="plateauVrSlider" min="0.5" max="2.0" value="1.0" step="0.1">
                        <div class="dual-input"><input type="number" class="numeric-input" id="plateauVrNum" value="1.0" step="0.1" min="0.5" max="2.0"></div>
                    </div>
                    <div class="slider-group">
                        <div class="slider-header"><span>Duración inspiración a TLC</span><span id="inspToTlcLabel">2.5 s</span></div>
                        <input type="range" class="slider" id="inspToTlcSlider" min="1.0" max="4.0" value="2.5" step="0.2">
                        <div class="dual-input"><input type="number" class="numeric-input" id="inspToTlcNum" value="2.5" step="0.2" min="1.0" max="4.0"></div>
                    </div>
                    <div class="slider-group">
                        <div class="slider-header"><span>Apnea en TLC (hold)</span><span id="apneaTlcLabel">8.0 s</span></div>
                        <input type="range" class="slider" id="apneaTlcSlider" min="4.0" max="12.0" value="8.0" step="0.5">
                        <div class="dual-input"><input type="number" class="numeric-input" id="apneaTlcNum" value="8.0" step="0.5" min="4.0" max="12.0"></div>
                    </div>
                    <div class="slider-group">
                        <div class="slider-header"><span>Espiración final a VR</span><span id="finalExpLabel">3.0 s</span></div>
                        <input type="range" class="slider" id="finalExpSlider" min="1.0" max="5.0" value="3.0" step="0.2">
                        <div class="dual-input"><input type="number" class="numeric-input" id="finalExpNum" value="3.0" step="0.2" min="1.0" max="5.0"></div>
                    </div>
                </div>

                <!-- Resultado DLCO calculado (simulado) -->
                <div class="card-panel">
                    <div class="card-title">📈 DLCO calculado</div>
                    <div class="dlco-predicho">
                        <div class="label">Capacidad de difusión (estimada)</div>
                        <div class="value" id="dlcoFinal">18.5</div>
                        <div class="unit">mL/min/mmHg</div>
                    </div>
                    <div style="margin-top: 20px; background: #deebff; border-radius: 20px; padding: 12px; text-align: center; color: #0057a3;" id="dlcoInterpretacion">
                        Basado en VA y tiempo apnea
                    </div>
                </div>
            </div>

            <!-- Controles de simulación y velocidad -->
            <div class="time-controls-modern">
                <button class="btn-icon" id="playPauseBtn"><span id="playIcon">⏸️</span> <span id="playText">Pausar</span></button>
                <button class="btn-icon" id="resetBtn"><span>↺</span> Reiniciar</button>
                <div style="flex:1; min-width:200px;">
                    <div style="color:#003f7a;">Velocidad simulación <span id="speedValue">1.0x</span></div>
                    <input type="range" id="speed-slider" min="0.25" max="2.0" value="1.0" step="0.25" class="slider">
                </div>
            </div>
        </div>
    </div>

    <script>
        (function() {
            const canvas = document.getElementById('dlcoCanvas');
            const ctx = canvas.getContext('2d');
            const width = canvas.width;
            const height = canvas.height;
            const margin = { top: 40, right: 60, bottom: 50, left: 70 };
            const graphWidth = width - margin.left - margin.right;
            const graphHeight = height - margin.top - margin.bottom;

            // Volúmenes (compartidos con el slider)
            let volumes = {
                vt: 0.5,
                vri: 2.5,
                vre: 1.1,
                vr: 1.2
            };

            // Tiempos específicos de maniobra DLCO
            let times = {
                expToVr: 3.0,      // espiración desde CRF hasta VR
                plateauVr: 1.0,     // meseta en VR (1s)
                inspToTlc: 2.5,     // inspiración desde VR a TLC
                apneaTlc: 8.0,       // apnea en TLC (8s)
                finalExp: 3.0        // espiración final de TLC a VR
            };

            // Estado de simulación
            let simTime = 0;
            let isPlaying = true;
            let speed = 1.0;
            let lastTimestamp = 0;
            let points = [];          // { time, volume }
            const maxPoints = 2000;
            const timeWindow = 40;     // segundos visibles (para ver apnea larga)

            // Estado maniobra
            let maneuverActive = false;
            let maneuverStartTime = 0;
            let maneuverPhase = 'none';

            // Elementos DOM
            const vtSlider = document.getElementById('vt-slider');
            const vriSlider = document.getElementById('vri-slider');
            const vreSlider = document.getElementById('vre-slider');
            const vrSlider = document.getElementById('vr-slider');
            const vtNum = document.getElementById('vtNum');
            const vriNum = document.getElementById('vriNum');
            const vreNum = document.getElementById('vreNum');
            const vrNum = document.getElementById('vrNum');
            const vtValLabel = document.getElementById('vtValLabel');
            const vriValLabel = document.getElementById('vriValLabel');
            const vreValLabel = document.getElementById('vreValLabel');
            const vrValLabel = document.getElementById('vrValLabel');
            const vtDisplay = document.getElementById('vtDisplay');
            const vriDisplay = document.getElementById('vriDisplay');
            const vreDisplay = document.getElementById('vreDisplay');
            const vrDisplay = document.getElementById('vrDisplay');

            const expToVrSlider = document.getElementById('expToVrSlider');
            const plateauVrSlider = document.getElementById('plateauVrSlider');
            const inspToTlcSlider = document.getElementById('inspToTlcSlider');
            const apneaTlcSlider = document.getElementById('apneaTlcSlider');
