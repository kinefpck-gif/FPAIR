            // Capacidades calculadas
            function calcCapacities() {
                const ci = volumes.vt + volumes.vri;
                const crf = volumes.vre + volumes.vr;
                const cvf = volumes.vri + volumes.vt + volumes.vre;
                const cpt = cvf + volumes.vr;
                return { ci, crf, cvf, cpt };
            }

            // Actualizar displays de volumen y etiquetas
            function updateVolumeDisplays() {
                vtValLabel.innerText = volumes.vt.toFixed(2)+' L'; vtNum.value = volumes.vt.toFixed(2); vtDisplay.innerText = volumes.vt.toFixed(2);
                vriValLabel.innerText = volumes.vri.toFixed(2)+' L'; vriNum.value = volumes.vri.toFixed(2); vriDisplay.innerText = volumes.vri.toFixed(2);
                vreValLabel.innerText = volumes.vre.toFixed(2)+' L'; vreNum.value = volumes.vre.toFixed(2); vreDisplay.innerText = volumes.vre.toFixed(2);
                vrValLabel.innerText = volumes.vr.toFixed(2)+' L'; vrNum.value = volumes.vr.toFixed(2); vrDisplay.innerText = volumes.vr.toFixed(2);
                
                expToVrLabel.innerText = times.expToVr.toFixed(1)+' s'; expToVrNum.value = times.expToVr.toFixed(1);
                plateauVrLabel.innerText = times.plateauVr.toFixed(1)+' s'; plateauVrNum.value = times.plateauVr.toFixed(1);
                inspToTlcLabel.innerText = times.inspToTlc.toFixed(1)+' s'; inspToTlcNum.value = times.inspToTlc.toFixed(1);
                apneaTlcLabel.innerText = times.apneaTlc.toFixed(1)+' s'; apneaTlcNum.value = times.apneaTlc.toFixed(1);
                finalExpLabel.innerText = times.finalExp.toFixed(1)+' s'; finalExpNum.value = times.finalExp.toFixed(1);

                const caps = calcCapacities();
                tlcVrLive.innerText = caps.cpt.toFixed(1)+' / '+volumes.vr.toFixed(1)+' L';
            }

            // Calcular DLCO simulado (en función del volumen inspiratorio y tiempo apnea)
            function calcularDLCO() {
                const caps = calcCapacities();
                const vi = caps.cpt - volumes.vr; // volumen inspirado desde VR hasta TLC
                const tiempoApnea = times.apneaTlc;
                // Fórmula ilustrativa: DLCO = (VI * 4.5) + (tiempoApnea * 0.8) + 5
                let dlco = (vi * 4.5) + (tiempoApnea * 0.8) + 5;
                dlco = Math.min(35, Math.max(8, Math.round(dlco * 10) / 10));
                return dlco;
            }

            function refreshDLCO() {
                const dlco = calcularDLCO();
                dlcoFinal.innerText = dlco;
                dlcoLive.innerText = dlco + ' mL/min/mmHg';
                if (dlco < 12) dlcoInterpretacion.innerText = 'DLCO reducido (simulado)';
                else if (dlco < 18) dlcoInterpretacion.innerText = 'DLCO normal-bajo';
                else if (dlco < 25) dlcoInterpretacion.innerText = 'DLCO normal';
                else dlcoInterpretacion.innerText = 'DLCO alto';
            }

            // Lógica de volumen basal VT (similar al CVF, basado en CRF)
            function calculateBasalVolume(t, caps) {
                const ti = 1.5, te = 2.5, tpausei=0.2, tpausee=0.2; // tiempos fijos para VT
                const totalCycle = ti + te + tpausei + tpausee;
                const tCycle = t % totalCycle;
                const baseVolume = caps.crf;
                
                if (tCycle < ti) {
                    // inspiración VT
                    const p = tCycle / ti;
                    return baseVolume + (volumes.vt * Math.sin(p * Math.PI/2));
                } else if (tCycle < ti + tpausei) {
                    return baseVolume + volumes.vt;
                } else if (tCycle < ti + tpausei + te) {
                    const p = (tCycle - ti - tpausei) / te;
                    return baseVolume + volumes.vt - (volumes.vt * Math.sin(p * Math.PI/2));
                } else {
                    return baseVolume;
                }
            }

            // Volumen durante maniobra DLCO
            function calculateManeuverVolume(t, caps) {
                const tm = t - maneuverStartTime;
                // Orden: 
                // 1. Espiración desde CRF a VR (expToVr duración)
                // 2. Meseta en VR (plateauVr)
                // 3. Inspiración desde VR a TLC (inspToTlc)
                // 4. Apnea en TLC (apneaTlc) -> sin cambio de volumen
                // 5. Espiración final desde TLC a VR (finalExp)
                let tiempoAcum = 0;

                // Fase 1: espiración a VR
                if (tm < times.expToVr) {
                    let p = tm / times.expToVr;
                    let vol = caps.crf - (caps.crf - volumes.vr) * Math.sin(p * Math.PI/2);
                    return { volume: vol, phase: 'exp', name: 'Espiración a VR' };
                }
                tiempoAcum += times.expToVr;

                // Fase 2: meseta en VR (1 segundo)
                if (tm < tiempoAcum + times.plateauVr) {
                    return { volume: volumes.vr, phase: 'pause', name: 'Meseta VR' };
                }
                tiempoAcum += times.plateauVr;

                // Fase 3: inspiración máxima a TLC
                if (tm < tiempoAcum + times.inspToTlc) {
                    let p = (tm - tiempoAcum) / times.inspToTlc;
                    let vol = volumes.vr + (caps.cpt - volumes.vr) * Math.sin(p * Math.PI/2);
                    return { volume: vol, phase: 'insp', name: 'Insp a TLC' };
                }
                tiempoAcum += times.inspToTlc;

                // Fase 4: apnea en TLC (8 segundos, volumen constante)
                if (tm < tiempoAcum + times.apneaTlc) {
                    return { volume: caps.cpt, phase: 'hold', name: 'Apnea TLC (8s)' };
                }
                tiempoAcum += times.apneaTlc;

                // Fase 5: espiración final a VR
                if (tm < tiempoAcum + times.finalExp) {
                    let p = (tm - tiempoAcum) / times.finalExp;
                    let vol = caps.cpt - (caps.cpt - volumes.vr) * Math.sin(p * Math.PI/2);
                    return { volume: vol, phase: 'exp', name: 'Espiración final' };
                }
                tiempoAcum += times.finalExp;

                // Maniobra terminada, volver a VT basal
                maneuverActive = false;
                maneuverStatus.innerText = 'Maniobra DLCO completada · VT basal';
                liveStatusHeader.innerText = 'VT BASAL';
                dlcoManeuverBtn.style.background = 'linear-gradient(145deg, #0057a3, #003f7a)';
                dlcoManeuverBtn.innerHTML = '<span>🫁</span> INICIAR MANIOBRA DLCO (espiración a VR → insp TLC → apnea 8s → espiración) <span>⏱️</span>';
                return calculateBasalVolume(t, caps);
            }

            function getCurrentVolume(t) {
                const caps = calcCapacities();
                if (maneuverActive) {
                    let res = calculateManeuverVolume(t, caps);
                    if (!maneuverActive) return calculateBasalVolume(t, caps);
                    return res.volume;
                } else {
                    return calculateBasalVolume(t, caps);
                }
            }

            function getCurrentPhase(t) {
                if (!maneuverActive) return { phase: 'VT', name: 'VT basal' };
                const caps = calcCapacities();
                const tm = t - maneuverStartTime;
                let acc = 0;
                if (tm < times.expToVr) return { phase: 'exp', name: 'Espirando a VR' };
                acc += times.expToVr;
                if (tm < acc + times.plateauVr) return { phase: 'pause', name: 'Meseta VR' };
                acc += times.plateauVr;
                if (tm < acc + times.inspToTlc) return { phase: 'insp', name: 'Inspirando a TLC' };
                acc += times.inspToTlc;
                if (tm < acc + times.apneaTlc) return { phase: 'hold', name: 'Apnea TLC' };
                acc += times.apneaTlc;
                if (tm < acc + times.finalExp) return { phase: 'exp', name: 'Espiración final' };
                return { phase: 'VT', name: 'VT basal' };
            }

            // Dibujar gráfico (con líneas de VT, VR, TLC) - AHORA COMIENZA EN TIEMPO 0 A LA IZQUIERDA
            function drawGraph() {
                ctx.clearRect(0,0,width,height);
                ctx.fillStyle = '#fafdff';
                ctx.fillRect(0,0,width,height);
                ctx.fillStyle = '#ffffff';
                ctx.fillRect(margin.left,margin.top,graphWidth,graphHeight);

                const caps = calcCapacities();
                const maxVol = caps.cpt + 0.5;

                // cuadrícula suave
                ctx.strokeStyle = '#c7d7f0'; ctx.lineWidth = 0.6; ctx.setLineDash([5,4]);
                for (let i=0; i<=7; i++) {
                    let y = margin.top + graphHeight - (i/maxVol)*graphHeight;
                    ctx.beginPath(); ctx.moveTo(margin.left,y); ctx.lineTo(margin.left+graphWidth,y); ctx.strokeStyle='#d4e2ff'; ctx.stroke();
                    ctx.fillStyle='#5f7d9c'; ctx.font='11px Inter'; ctx.fillText(i+' L', margin.left-32, y+4);
                }
                
                // Eje de tiempo: de 0 a timeWindow segundos, de izquierda a derecha
                for (let i=0; i<=timeWindow; i+=5) {
                    let x = margin.left + (i/timeWindow)*graphWidth;
                    ctx.beginPath(); ctx.moveTo(x,margin.top); ctx.lineTo(x,margin.top+graphHeight); ctx.strokeStyle='#d4e2ff'; ctx.stroke();
                    ctx.fillStyle='#5f7d9c'; ctx.fillText(i+'s', x-15, margin.top+graphHeight+20);
                }
                ctx.setLineDash([]);

                // Líneas de referencia: CRF, VT insp, VR, TLC
                const crf = caps.crf;
                const vtInspLevel = crf + volumes.vt;
                
                // Línea CRF (base espiratoria) en naranja
                ctx.beginPath(); ctx.strokeStyle = '#f39c12'; ctx.lineWidth = 2; ctx.setLineDash([8,5]);
                let yCrf = margin.top + graphHeight - (crf / maxVol)*graphHeight;
                ctx.moveTo(margin.left, yCrf); ctx.lineTo(margin.left+graphWidth, yCrf); ctx.stroke();
                ctx.fillStyle = '#f39c12'; ctx.fillText('CRF', margin.left+graphWidth+8, yCrf-5);
                
                // Línea VT insp máximo en azul
                ctx.beginPath(); ctx.strokeStyle = '#0057a3'; ctx.lineWidth = 2; ctx.setLineDash([8,5]);
                let yVtInsp = margin.top + graphHeight - (vtInspLevel / maxVol)*graphHeight;
                ctx.moveTo(margin.left, yVtInsp); ctx.lineTo(margin.left+graphWidth, yVtInsp); ctx.stroke();
                ctx.fillStyle = '#0057a3'; ctx.fillText('VT insp', margin.left+graphWidth+8, yVtInsp-5);
                
                // VR línea verde
                let yVr = margin.top + graphHeight - (volumes.vr / maxVol)*graphHeight;
                ctx.beginPath(); ctx.strokeStyle = '#2ecc71'; ctx.lineWidth = 2; ctx.setLineDash([8,5]);
                ctx.moveTo(margin.left, yVr); ctx.lineTo(margin.left+graphWidth, yVr); ctx.stroke();
                ctx.fillStyle = '#2ecc71'; ctx.fillText('VR', margin.left+graphWidth+8, yVr-5);
                
                // TLC línea púrpura
                let yTlc = margin.top + graphHeight - (caps.cpt / maxVol)*graphHeight;
                ctx.beginPath(); ctx.strokeStyle = '#9b59b6'; ctx.lineWidth = 2; ctx.setLineDash([8,5]);
                ctx.moveTo(margin.left, yTlc); ctx.lineTo(margin.left+graphWidth, yTlc); ctx.stroke();
                ctx.fillStyle = '#9b59b6'; ctx.fillText('TLC', margin.left+graphWidth+8, yTlc-5);
                
                ctx.setLineDash([]);

                // Curva de volumen - ahora tiempo 0 en borde izquierdo, tiempo actual en el punto correspondiente
                if (points.length > 1) {
                    ctx.beginPath(); ctx.strokeStyle = maneuverActive ? '#c44545' : '#4facfe'; ctx.lineWidth = 3;
                    
                    // El tiempo más antiguo en la ventana es 0 (siempre mostramos desde 0 hasta simTime)
                    const minTime = 0;
                    const maxTime = Math.max(simTime, timeWindow); // Para escalar correctamente, usamos maxTime = timeWindow si simTime < timeWindow
                    
                    // Escalamos el tiempo de forma que 0 esté en borde izquierdo y timeWindow en borde derecho
                    // Si simTime es menor que timeWindow, comprimimos los puntos en la ventana
                    let firstPointInside = true;
                    
                    for (let i=0; i<points.length; i++) {
                        // Calculamos posición x: desde 0 hasta timeWindow segundos
                        let t = points[i].time;
                        // Si t > timeWindow, lo desplazamos para que se vea dentro de la ventana
                        // Queremos mostrar siempre los últimos timeWindow segundos, con 0 en el borde izquierdo
                        // Para ello, mostramos desde max(0, simTime-timeWindow) hasta simTime
                        // Pero como queremos que 0 esté en el borde izquierdo, usamos un enfoque diferente:
                        // Mostramos desde 0 hasta timeWindow, pero si simTime > timeWindow, desplazamos
                        let displayTime = t;
                        if (simTime > timeWindow) {
                            displayTime = t - (simTime - timeWindow);
                        }
                        // displayTime ahora está entre 0 y timeWindow aproximadamente
                        
                        if (displayTime >= 0 && displayTime <= timeWindow) {
                            let x = margin.left + (displayTime / timeWindow) * graphWidth;
                            let y = margin.top + graphHeight - (points[i].volume / maxVol)*graphHeight;
                            
                            if (x >= margin.left && x <= margin.left + graphWidth) {
                                if (firstPointInside) {
                                    ctx.moveTo(x, y);
                                    firstPointInside = false;
                                } else {
                                    ctx.lineTo(x, y);
                                }
                            } else {
                                firstPointInside = true;
                            }
                        } else {
                            firstPointInside = true;
                        }
                    }
                    ctx.stroke();
                }
            }

            function animate(ts) {
                if(!lastTimestamp){ lastTimestamp=ts; requestAnimationFrame(animate); return; }
                if(isPlaying) {
                    let dt = (ts-lastTimestamp)/1000 * speed;
                    simTime += dt;
                    let vol = getCurrentVolume(simTime);
                    let phaseInfo = getCurrentPhase(simTime);
                    
                    currentVolLive.innerText = vol.toFixed(2) + ' L';
                    currentPhaseLive.innerText = phaseInfo.name;
                    
                    vtPhaseTag.classList.remove('active-insp','active-exp','active-pause','active-hold');
                    expPhaseTag.classList.remove('active-insp','active-exp','active-pause','active-hold');
                    inspPhaseTag.classList.remove('active-insp','active-exp','active-pause','active-hold');
                    holdPhaseTag.classList.remove('active-insp','active-exp','active-pause','active-hold');

                    if (!maneuverActive) {
                        vtPhaseTag.classList.add('active-insp');
                    } else {
                        if (phaseInfo.phase === 'exp') expPhaseTag.classList.add('active-exp');
                        else if (phaseInfo.phase === 'insp') inspPhaseTag.classList.add('active-insp');
                        else if (phaseInfo.phase === 'hold') holdPhaseTag.classList.add('active-hold');
                        else if (phaseInfo.phase === 'pause') vtPhaseTag.classList.add('active-pause');
                    }

                    points.push({ time: simTime, volume: vol });
                    // Mantener puntos relevantes (últimos timeWindow segundos)
                    points = points.filter(p => p.time > simTime - timeWindow - 2);
                    if (points.length > maxPoints) points = points.slice(-maxPoints);
                }
                drawGraph();
                lastTimestamp = ts;
                requestAnimationFrame(animate);
            }

            // Event listeners
            function bindAll() {
                vtSlider.addEventListener('input', (e)=>{ volumes.vt = parseFloat(e.target.value); updateVolumeDisplays(); refreshDLCO(); });
                vriSlider.addEventListener('input', (e)=>{ volumes.vri = parseFloat(e.target.value); updateVolumeDisplays(); refreshDLCO(); });
                vreSlider.addEventListener('input', (e)=>{ volumes.vre = parseFloat(e.target.value); updateVolumeDisplays(); refreshDLCO(); });
                vrSlider.addEventListener('input', (e)=>{ volumes.vr = parseFloat(e.target.value); updateVolumeDisplays(); refreshDLCO(); });
                
                vtNum.addEventListener('input', (e)=>{ let v=parseFloat(e.target.value)||0.5; volumes.vt=Math.min(1,Math.max(0.2,v)); vtSlider.value=volumes.vt; updateVolumeDisplays(); refreshDLCO(); });
                vriNum.addEventListener('input', (e)=>{ let v=parseFloat(e.target.value)||2.5; volumes.vri=Math.min(3.5,Math.max(1.0,v)); vriSlider.value=volumes.vri; updateVolumeDisplays(); refreshDLCO(); });
                vreNum.addEventListener('input', (e)=>{ let v=parseFloat(e.target.value)||1.1; volumes.vre=Math.min(1.8,Math.max(0.5,v)); vreSlider.value=volumes.vre; updateVolumeDisplays(); refreshDLCO(); });
                vrNum.addEventListener('input', (e)=>{ let v=parseFloat(e.target.value)||1.2; volumes.vr=Math.min(2.0,Math.max(0.8,v)); vrSlider.value=volumes.vr; updateVolumeDisplays(); refreshDLCO(); });

                expToVrSlider.addEventListener('input', (e)=>{ times.expToVr = parseFloat(e.target.value); updateVolumeDisplays(); refreshDLCO(); });
                plateauVrSlider.addEventListener('input', (e)=>{ times.plateauVr = parseFloat(e.target.value); updateVolumeDisplays(); refreshDLCO(); });
                inspToTlcSlider.addEventListener('input', (e)=>{ times.inspToTlc = parseFloat(e.target.value); updateVolumeDisplays(); refreshDLCO(); });
                apneaTlcSlider.addEventListener('input', (e)=>{ times.apneaTlc = parseFloat(e.target.value); updateVolumeDisplays(); refreshDLCO(); });
                finalExpSlider.addEventListener('input', (e)=>{ times.finalExp = parseFloat(e.target.value); updateVolumeDisplays(); refreshDLCO(); });

                expToVrNum.addEventListener('input', (e)=>{ let v=parseFloat(e.target.value)||3.0; times.expToVr=Math.min(5,Math.max(1,v)); expToVrSlider.value=times.expToVr; updateVolumeDisplays(); refreshDLCO(); });
                plateauVrNum.addEventListener('input', (e)=>{ let v=parseFloat(e.target.value)||1.0; times.plateauVr=Math.min(2,Math.max(0.5,v)); plateauVrSlider.value=times.plateauVr; updateVolumeDisplays(); refreshDLCO(); });
                inspToTlcNum.addEventListener('input', (e)=>{ let v=parseFloat(e.target.value)||2.5; times.inspToTlc=Math.min(4,Math.max(1,v)); inspToTlcSlider.value=times.inspToTlc; updateVolumeDisplays(); refreshDLCO(); });
                apneaTlcNum.addEventListener('input', (e)=>{ let v=parseFloat(e.target.value)||8.0; times.apneaTlc=Math.min(12,Math.max(4,v)); apneaTlcSlider.value=times.apneaTlc; updateVolumeDisplays(); refreshDLCO(); });
                finalExpNum.addEventListener('input', (e)=>{ let v=parseFloat(e.target.value)||3.0; times.finalExp=Math.min(5,Math.max(1,v)); finalExpSlider.value=times.finalExp; updateVolumeDisplays(); refreshDLCO(); });
            }

            dlcoManeuverBtn.addEventListener('click', ()=>{
                if (!maneuverActive) {
                    maneuverActive = true;
                    maneuverStartTime = simTime;
                    maneuverStatus.innerText = 'Maniobra DLCO en curso: espiración → meseta VR → insp TLC → apnea 8s → espiración final';
                    liveStatusHeader.innerText = 'MANIOBRA DLCO';
                    dlcoManeuverBtn.style.background = 'linear-gradient(145deg, #3d9e5a, #257545)';
                    dlcoManeuverBtn.innerHTML = '<span>✓</span> MANIOBRA DLCO EN CURSO... <span>⏱️</span>';
                }
            });

            playPauseBtn.addEventListener('click', ()=>{ isPlaying=!isPlaying; playIcon.innerText=isPlaying?'⏸️':'▶️'; playText.innerText=isPlaying?'Pausar':'Reanudar'; });
            resetBtn.addEventListener('click', ()=>{ simTime=0; points=[]; maneuverActive=false; maneuverStatus.innerText='VT basal · esperando inicio de maniobra'; liveStatusHeader.innerText='VT BASAL'; dlcoManeuverBtn.style.background='linear-gradient(145deg, #0057a3, #003f7a)'; dlcoManeuverBtn.innerHTML='<span>🫁</span> INICIAR MANIOBRA DLCO (espiración a VR → insp TLC → apnea 8s → espiración) <span>⏱️</span>'; });
            speedSlider.addEventListener('input', (e)=>{ speed=parseFloat(e.target.value); speedValue.innerText=speed.toFixed(2)+'x'; });

            bindAll();
            updateVolumeDisplays();
            refreshDLCO();
            requestAnimationFrame(animate);
        })();
    </script>
